# Database
DB_HOST=localhost
DB_PORT=5432
DB_USER=civ_user
DB_PASSWORD=civ_pass
DB_NAME=civ_db

# Azure OpenAI — copy this file to .env and fill in your values
AZURE_OPENAI_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource-name>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-4o
AZURE_OPENAI_API_VERSION=2024-02-01

# AI feature flags (set AI_ENABLED=true to activate LLM features)
AI_ENABLED=false
AI_MAX_CALLS_PER_RUN=3
AI_SUMMARY_ENABLED=true
AI_ASK_AGENT_ENABLED=true

# App
APP_ENV=development
LOG_LEVEL=INFO

# Simulation limits
AUTOPLAY_MAX_TURNS=20
